# ============================================
# AI Tutor Configuration
# ============================================

# ⭐ RECOMMENDED: Google Gemini API Key (COMPLETELY FREE)
# Get from: https://makersuite.google.com/app/apikey
# 1,500 free requests per day = ~100 students
GEMINI_API_KEY=your-gemini-api-key-here

# Alternative: OpenAI API Key (Paid)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-api-key-here

# OPTIONAL: Google Cloud Services (for advanced features)
# For translation: https://cloud.google.com/translate/docs/setup
# GOOGLE_TRANSLATE_API_KEY=your-google-key-here

# Path to Google Cloud credentials JSON file (optional)
# Needed for: Text-to-Speech, Speech-to-Text
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# OPTIONAL: Development/Debug
DEBUG=False
LOG_LEVEL=INFO

# ============================================
# Model Configuration (override defaults)
# ============================================

# LLM Model (gpt-4 recommended, gpt-3.5-turbo for cost savings)
# GPT_MODEL=gpt-3.5-turbo

# Embedding Model
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# Database Configuration
# ============================================

# ChromaDB data directory (default: data/chroma_db)
# CHROMA_DB_DIR=data/chroma_db

# NCERT PDFs directory (default: data/ncert_pdfs)
# NCERT_PDF_DIR=data/ncert_pdfs
